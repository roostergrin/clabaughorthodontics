.form-contact
  form.form-contact__form
    
    .form-contact__group
      label.form-contact__label Your Name *
      input.form-contact__input(name='fullName', v-model='fullName', v-validate="'required'", :class="{ 'form-contact__input--error': errors.has('fullName') }", type='text')
      .form-contact__error-message(v-show="errors.has('fullName')") Your name is required.
      
    .form-contact__group
      label.form-contact__label Your Email *
      input.form-contact__input(name='clientEmail', v-model='clientEmail', v-validate="'required|email'", :class="{ 'form-contact__input--error': errors.has('clientEmail') }")
      .form-contact__error-message(v-show="errors.has('clientEmail')")  Please input a valid email adress.
    
    .form-contact__group
      label.form-contact__label Your Phone Number *
      input.form-contact__input(name='clientPhone', v-model='clientPhone', v-validate="'required|numeric'", :class="{ 'form-contact__input--error': errors.has('clientPhone') }")
      .form-contact__error-message(v-show="errors.has('clientPhone')")  Please input a valid phone number.
      
    .form-contact__group
      .form-contact__checkbox
        .form-contact__checkbox-group
          input.form-contact__checkbox-input(
            name='isFirstTime'
            v-model='isFirstTime'
            value='Yes'
            type='checkbox')
          span.form-contact__checkbox-overlay
          label.form-contact__checkbox-label Yes, I am a first time patient!
    
    .form-contact__group
      label.form-contact__label.form-contact__label--textarea(:class="{ 'form-contact__label--active': clientMessage }") Message
      textarea.form-contact__input.form-contact__input--textarea(name='clientMessage', v-model='clientMessage' rows='4')
      .form-contact__error-message(v-show="errors.has('clientMessage')")  Please fill out your message
    
    .form-contact__group.form-contact__group--button
      .form-contact__submit-button(:class="{ 'form-contact__submit-button--success': formSuccess, 'form-contact__submit-button--sending': formSubmitted && !formSuccess }" @click='validate')
        span.form-contact__submit-label(:class="{ 'form-contact__submit-label--hidden': formSuccess }") Submit
        span.form-contact__submit-check(:class="{ 'form-contact__submit-check--showing': formSuccess }") &#10003
  
  .form-contact__modal(:class="{ 'form-contact__modal--open': modalOpen }")
    .form-contact__modal-overlay
    .form-contact__modal-container
      .form-contact__modal-close(@click='closeModal()') close
      h1.form-contact__modal-title Thank you! 
      .form-contact__modal-text We will be in touch shortly!
      slot
